{
  "manifest_version": 3,
  "name": "多语言查词助手",
  "version": "0.2.0",
  "description": "选中网页上的外语单词，自动分析转写、词源、词义和句中作用。",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://api.deepseek.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "打开多语言查词助手设置"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
